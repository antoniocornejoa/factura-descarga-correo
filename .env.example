# ====================================
# Factura Descarga Correo - Variables de Entorno
# ====================================
# Copia este archivo como .env y completa los valores

# --- Base de datos PostgreSQL ---
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/factura_correo

# --- Credenciales iConstruye ---
ICONSTRUYE_USERNAME=tu_usuario@ejemplo.cl
ICONSTRUYE_PASSWORD=tu_password_aqui

# --- Email destinatario ---
RECIPIENT_EMAIL=tu_email@ejemplo.cl

# --- Programacion cron (horario Chile) ---
SCHEDULE_CRON_EXPRESSION=0 23 * * *

# --- Sesion ---
SESSION_SECRET=genera_un_string_aleatorio_aqui

# --- Gmail OAuth2 ---
# Ejecuta "node scripts/get-gmail-token.mjs" para obtener el refresh_token
GMAIL_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=tu_client_secret
GMAIL_REFRESH_TOKEN=tu_refresh_token

# --- Entorno ---
NODE_ENV=production
